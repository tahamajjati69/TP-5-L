<%- include('../../partials/header') %>

<section class="form-card">
  <h1>Ajouter un livre</h1>

  <form action="/livres/ajouter" method="POST" class="form-grid">
    <div class="full-width">
      <label>Titre</label>
      <input type="text" name="titre" required>
    </div>

    <div>
      <label>Auteur</label>
      <select name="auteur_id" required>
        <option value="">-- Choisir un auteur --</option>
        <% auteurs.forEach(auteur => { %>
          <option value="<%= auteur.id %>"><%= auteur.prenom %> <%= auteur.nom %></option>
        <% }) %>
      </select>
    </div>

    <div>
      <label>Année de publication</label>
      <input type="number" name="annee_publication">
    </div>

    <div>
      <label>Genre</label>
      <input type="text" name="genre">
    </div>

    <div>
      <label>ISBN</label>
      <input type="text" name="isbn">
    </div>

    <div class="full-width">
      <label>Résumé</label>
      <textarea name="resume" rows="5"></textarea>
    </div>

    <div class="full-width checkbox-group">
      <label>
        <input type="checkbox" name="disponible" checked>
        Disponible
      </label>
    </div>

    <div class="full-width form-actions">
      <button type="submit" class="btn">Ajouter</button>
      <a href="/livres" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</section>

<%- include('../../partials/footer') %>